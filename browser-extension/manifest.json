{
  "manifest_version": 3,
  "name": "vCenter 多语言界面 (vcf-rosetta)",
  "version": "3.1.0",
  "description": "将 vCenter Server / VCF 9.x UI 实时翻译为简体中文或德文,无需修改 vCenter 服务器。基于官方 + 审定术语词表。",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "vCenter 多语言界面"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "content/translator.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dict.*.json"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ]
}
