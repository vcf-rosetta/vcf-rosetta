{
    "manifestVersion": "1.2.0",
    "requirements": {
        "plugin.api.version": "1.2.0",
        "vcenter.server": {
            "version": "[7.0,)",
            "environments": [
                "onprem"
            ]
        }
    },
    "configuration": {
        "nameKey": "vcfrosetta.plugin.name"
    },
    "objects": {
        "Folder:RootFolder": {
            "monitor": {
                "views": [
                    {
                        "navigationId": "vcfrosetta-r1-probe",
                        "labelKey": "vcfrosetta.r1.title",
                        "uri": "index.html"
                    }
                ],
                "forceExpand": true
            }
        }
    },
    "definitions": {
        "i18n": {
            "locales": [
                "en-US",
                "zh-CN"
            ],
            "definitions": {
                "vcfrosetta.plugin.name": {
                    "en-US": "VCF Rosetta (R1 Probe)",
                    "zh-CN": "VCF Rosetta(R1 验证)"
                },
                "vcfrosetta.r1.title": {
                    "en-US": "Locale Routing Probe",
                    "zh-CN": "语言路由验证"
                }
            }
        }
    }
}
