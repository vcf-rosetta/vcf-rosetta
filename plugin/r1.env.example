# Copy to r1.env and fill in. `prepare.sh` reads this.
# Only PLUGIN_HOST is strictly required to generate the cert; the rest are
# needed for the registration step.

# FQDN of THIS plug-in server host, as vCenter will reach it.
# Must be DNS-resolvable from vCenter. Leave blank to auto-detect (hostname -f).
PLUGIN_HOST=

# Port the plug-in HTTPS server listens on.
PORT=8443

# vCenter you are registering against.
VC_HOST=vcenter.your-domain.com
VC_USER=administrator@vsphere.local

# Path to the unzipped vSphere Client SDK 9.0 (prepare.sh hunts for the
# registration tool jar under here). Leave blank to skip auto-find.
SDK_DIR=
